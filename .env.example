# Copy to .env and fill in. Either key works; Groq preferred for speed.
# Groq (free, no card): https://console.groq.com -> API Keys
GROQ_API_KEY=
# Google AI Studio (free, no card): https://aistudio.google.com -> Get API key
GEMINI_API_KEY=
# Provider: groq | gemini | mock  (mock = deterministic, offline, for dev/tests)
LLM_PROVIDER=mock
